# Project Sekai API Data Capture System - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# Receiver Configuration
# ============================================
# Receiver port (default: 3939)
RECEIVER_PORT=3939

# Server public IP or domain for external access
PUBLIC_HOST=your-server-ip-or-domain.com

# API region: cn, tw, etc.
API_REGION=cn

# Root directory for output data
OUTPUT_ROOT=/data

# Path to MySekai resource mapping configuration
MYSEKAI_RESOURCE_MAP_JSON=/data/config/mysekai_resource_map.json

# Number of recent files to retain (default: 25)
RETENTION_COUNT=25

# ============================================
# Bot Push Configuration (NapCat)
# ============================================
# Enable bot push notifications (1: enabled, 0: disabled)
BOT_PUSH_ENABLED=1

# NapCat HTTP API base URL (default: http://napcat:3000)
BOT_PUSH_URL=http://napcat:3000

# Push mode: "private" or "group"
BOT_PUSH_MODE=group

# Target ID (QQ user ID for private, group ID for group)
BOT_TARGET_ID=your-target-id

# User label for notifications (e.g., player, user, etc.)
NOTIFICATION_USER_LABEL=player

# NapCat HTTP API token
BOT_TOKEN=your-napcat-token

# Retry count for failed push attempts
BOT_PUSH_RETRY=3

# Message mode: "text", "image", or "text+image"
BOT_MESSAGE_MODE=text+image

# ============================================
# Rendering Configuration
# ============================================
# MySekai map image output width in pixels
MYSEKAI_MAP_IMAGE_SIZE=1024

# Icon size in pixels
MYSEKAI_ICON_SIZE=36

# Count font size in pixels
MYSEKAI_COUNT_FONT_SIZE=18

# Icon spread distance in pixels
MYSEKAI_ICON_SPREAD=22

# Icon enhancement settings (1: enabled, 0: disabled)
MYSEKAI_ICON_ENHANCE=1

# Icon sharpness radius (0.0-1.0)
MYSEKAI_ICON_SHARP_RADIUS=0.8

# Icon sharpness percentage (typically 100-200)
MYSEKAI_ICON_SHARP_PERCENT=130

# Icon sharpness threshold
MYSEKAI_ICON_SHARP_THRESHOLD=2

# ============================================
# Notification Configuration
# ============================================
# Notification deduplication window cache in hours
NOTIFICATION_WINDOW_CACHE_HOURS=72

# Number of notification hits to retain in archive
NOTIFICATION_HIT_RETENTION=100

# Maximum number of lines in diamond notifications log
NOTIFICATION_EVENT_RETENTION_LINES=5000

# ============================================
# Plugin Query Configuration
# ============================================
# Plugin API key (optional, for authentication)
PLUGIN_API_KEY=

# Number of plugin query images to retain
PLUGIN_QUERY_IMAGE_RETENTION=25

# ============================================
# System Configuration
# ============================================
# Timezone setting
TZ=Asia/Shanghai